# PostgreSQL connection string (Railway, Supabase, Neon, etc.)
# Railway format: postgresql://postgres:password@host.railway.app:5432/railway
DATABASE_URL="postgresql://user:password@host:5432/duolync"

# Better Auth — generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# Public app URL (used by auth client)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# IMPORTANT: Pick one host everywhere (localhost vs 127.0.0.1). Must match BETTER_AUTH_URL and the URL you open in the browser, or OAuth cookies/state will mismatch.

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS="http://localhost:3000"

# Google Cloud Console (OAuth 2.0 Web client):
# - Authorized JavaScript origins: http://localhost:3000 (prod: https://your-domain.com)
# - Authorized redirect URIs: http://localhost:3000/api/auth/callback/google (prod: https://your-domain.com/api/auth/callback/google)
# BETTER_AUTH_URL should match the origin you use in the browser (same as redirect base).
# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth — https://developers.facebook.com/
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
